# Neo4j connection settings
# Copy this file to .env and fill in your values
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ── LLM (chat/) ────────────────────────────────────────────────────────────
# Primary: OpenAI. Fallback: OpenRouter (qwen ücretsiz tier).
# Biri tanımsızsa o tier otomatik atlanır.
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-v1-...

# Model override (opsiyonel) — tanımsızsa default'lar:
#   LLM_MODEL_PRIMARY  = gpt-4o-mini
#   LLM_MODEL_FALLBACK = qwen/qwen3-next-80b-a3b-instruct:free
# LLM_MODEL_PRIMARY=gpt-4o-mini
# LLM_MODEL_FALLBACK=qwen/qwen3-next-80b-a3b-instruct:free
