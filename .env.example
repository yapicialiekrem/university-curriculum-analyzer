# Neo4j connection settings
# Copy this file to .env and fill in your values
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ── Azure OpenAI (chat + enrichment primary) ──────────────────────────────
# Hem /api/chat (src/chat/llm.py) hem enrichment (src/enrichment) bu
# kredensiyellere bakar. AZURE_OPENAI_API_KEY tanımsızsa enrichment
# çalışmaz; chat OPENAI_API_KEY'e fallback eder.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_DEPLOYMENT=unicurriculum
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# ── LLM — chat/ alternatif rotalar ────────────────────────────────────────
# Azure yoksa OPENAI_API_KEY primary; fallback tier OpenRouter.
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Model override (opsiyonel) — tanımsızsa default'lar:
#   LLM_MODEL_PRIMARY  = gpt-4o-mini
#   LLM_MODEL_FALLBACK = qwen/qwen3-next-80b-a3b-instruct:free
# LLM_MODEL_PRIMARY=gpt-4o-mini
# LLM_MODEL_FALLBACK=qwen/qwen3-next-80b-a3b-instruct:free
